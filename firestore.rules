rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'updatedAt', 'createdBy'])
        && data.keys().size() >= 3
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (data.keys().hasAll(['type']) ? data.type in ['spirit', 'wine', 'soft_drink', 'other'] : true)
        && data.updatedAt == request.time
        && data.createdBy is string;
    }

    function isValidItem(data) {
      return data.keys().hasAll(['name', 'categoryId', 'unit', 'parLevel', 'currentStock', 'updatedAt', 'createdBy'])
        && data.keys().size() >= 7
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.categoryId is string && data.categoryId.size() <= 128
        && data.unit is string && data.unit.size() <= 20
        && data.parLevel is number && data.parLevel >= 0
        && data.currentStock is number
        && (data.keys().hasAll(['isGlass']) ? data.isGlass is bool : true)
        && (data.keys().hasAll(['type']) ? data.type in ['spirit', 'wine', 'soft_drink', 'other'] : true)
        && data.updatedAt == request.time
        && data.createdBy is string && data.createdBy.size() <= 128;
    }

    function isValidRecipe(data) {
      return data.keys().hasAll(['name', 'categoryId', 'ingredients', 'updatedAt', 'createdBy'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.categoryId is string
        && data.ingredients is list && data.ingredients.size() <= 50
        && data.updatedAt == request.time
        && data.createdBy is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['itemId', 'quantity', 'date', 'type', 'createdBy', 'createdAt'])
        && data.keys().size() >= 6
        && data.itemId is string && data.itemId.size() <= 128
        && data.quantity is number
        && data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.type in ['count', 'usage', 'delivery']
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time;
    }

    // --- Resources ---

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(categoryId) && isValidCategory(incoming()) && incoming().createdBy == request.auth.uid;
      allow update: if isSignedIn() && isValidCategory(incoming()) && incoming().createdBy == existing().createdBy;
      allow delete: if isSignedIn();
    }

    match /items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(itemId) && isValidItem(incoming()) && incoming().createdBy == request.auth.uid;
      allow update: if isSignedIn() && isValidItem(incoming()) 
                   && incoming().createdBy == existing().createdBy;
      allow delete: if isSignedIn();
    }

    match /recipes/{recipeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(recipeId) && isValidRecipe(incoming()) && incoming().createdBy == request.auth.uid;
      allow update: if isSignedIn() && isValidRecipe(incoming());
      allow delete: if isSignedIn();
    }

    match /inventoryLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(logId) && isValidLog(incoming());
      allow update: if isSignedIn() && isValidLog(incoming());
      allow delete: if isSignedIn();
    }
  }
}
